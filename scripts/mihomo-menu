#!/bin/bash
# mihomo-menu - mihomo-quick 统一管理菜单

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

MIHOMO_BIN="$HOME/.local/bin/mihomo-core"
CONFIG_DIR="$HOME/.config/mihomo"
SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

# 服务状态
service_status() {
    if systemctl is-active --quiet mihomo-tun 2>/dev/null; then
        echo -e "${GREEN}运行中 (TUN)${NC}"
    elif systemctl is-active --quiet mihomo 2>/dev/null; then
        echo -e "${GREEN}运行中${NC}"
    elif [ -f "$HOME/.cache/mihomo/mihomo.pid" ] && kill -0 "$(cat "$HOME/.cache/mihomo/mihomo.pid")" 2>/dev/null; then
        echo -e "${GREEN}运行中 (手动)${NC}"
    else
        echo -e "${YELLOW}未运行${NC}"
    fi
}

# 版本信息
version_info() {
    if [ -x "$MIHOMO_BIN" ]; then
        "$MIHOMO_BIN" -v 2>/dev/null | head -1 || echo "未知版本"
    else
        echo -e "${RED}未安装${NC}"
    fi
}

# 显示菜单
show_menu() {
    clear 2>/dev/null
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║                  mihomo-quick 管理菜单                      ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo -e "  版本: $(version_info) | 状态: $(service_status)"
    echo ""
    echo -e "  ${WHITE}服务管理${NC}"
    echo "   1) 🚀 启动服务 (普通模式)"
    echo "   2) 🚀 启动服务 (TUN 模式)"
    echo "   3) 🛑 停止服务"
    echo "   4) 🔄 重启服务"
    echo "   5) 📊 查看状态"
    echo ""
    echo -e "  ${WHITE}配置管理${NC}"
    echo "   6) 📦 添加订阅"
    echo "   7) 📜 管理规则"
    echo "   8) ✅ 校验配置"
    echo "   9) ⏪ 配置回滚"
    echo "  10) 📝 编辑配置"
    echo ""
    echo -e "  ${WHITE}维护${NC}"
    echo "  11) 📋 查看日志"
    echo "  12) 🔄 检查更新 (内核/面板/GeoIP)"
    echo "  13) 🔧 安装/更新服务 (开机自启)"
    echo "  14) 🧪 代理测试"
    echo ""
    echo -e "  ${WHITE}其他${NC}"
    echo "  15) 🗑️  卸载"
    echo "   0) 退出"
    echo ""
}

# 主循环
while true; do
    show_menu
    read -p "请选择 [0-15]: " choice
    echo ""

    case $choice in
        1)
            if [ -x "$SCRIPT_DIR/mihomo-start" ]; then
                "$SCRIPT_DIR/mihomo-start"
            else
                echo -e "${RED}❌ mihomo-start 脚本未找到${NC}"
            fi
            ;;
        2)
            echo "🚀 启动 TUN 模式..."
            if systemctl is-active --quiet mihomo-tun 2>/dev/null; then
                echo -e "${YELLOW}⚠️  mihomo-tun 服务已在运行${NC}"
            else
                sudo systemctl start mihomo-tun 2>/dev/null || {
                    echo -e "${YELLOW}⚠️  mihomo-tun 服务未安装，尝试通过 setup-service.sh tun 创建...${NC}"
                    if [ -f "$SCRIPT_DIR/../setup-service.sh" ]; then
                        bash "$SCRIPT_DIR/../setup-service.sh" tun
                    else
                        echo -e "${RED}❌ setup-service.sh 未找到${NC}"
                    fi
                }
            fi
            ;;
        3)
            if [ -x "$SCRIPT_DIR/mihomo-stop" ]; then
                "$SCRIPT_DIR/mihomo-stop"
            fi
            sudo systemctl stop mihomo 2>/dev/null
            sudo systemctl stop mihomo-tun 2>/dev/null
            echo -e "${GREEN}✅ 服务已停止${NC}"
            ;;
        4)
            echo "🔄 重启服务..."
            if systemctl is-active --quiet mihomo-tun 2>/dev/null; then
                sudo systemctl restart mihomo-tun
                echo -e "${GREEN}✅ mihomo-tun 已重启${NC}"
            elif systemctl is-active --quiet mihomo 2>/dev/null; then
                sudo systemctl restart mihomo
                echo -e "${GREEN}✅ mihomo 已重启${NC}"
            else
                echo -e "${YELLOW}⚠️  服务未在运行，尝试启动普通模式...${NC}"
                sudo systemctl start mihomo 2>/dev/null || echo -e "${RED}❌ 启动失败${NC}"
            fi
            ;;
        5)
            echo -e "${WHITE}=== mihomo 服务状态 ===${NC}"
            systemctl status mihomo --no-pager -l 2>/dev/null || echo "  mihomo 服务未安装"
            echo ""
            echo -e "${WHITE}=== mihomo-tun 服务状态 ===${NC}"
            systemctl status mihomo-tun --no-pager -l 2>/dev/null || echo "  mihomo-tun 服务未安装"
            echo ""
            if [ -x "$MIHOMO_BIN" ]; then
                echo -e "${WHITE}=== mihomo 版本 ===${NC}"
                "$MIHOMO_BIN" -v 2>/dev/null
            fi
            ;;
        6)
            if [ -x "$SCRIPT_DIR/mihomo-add-sub" ]; then
                "$SCRIPT_DIR/mihomo-add-sub"
            else
                echo -e "${RED}❌ mihomo-add-sub 脚本未找到${NC}"
            fi
            ;;
        7)
            if [ -x "$SCRIPT_DIR/mihomo-rules" ]; then
                "$SCRIPT_DIR/mihomo-rules"
            else
                echo -e "${RED}❌ mihomo-rules 脚本未找到${NC}"
            fi
            ;;
        8)
            if [ -x "$SCRIPT_DIR/mihomo-check" ]; then
                "$SCRIPT_DIR/mihomo-check"
            else
                echo -e "${RED}❌ mihomo-check 脚本未找到${NC}"
            fi
            ;;
        9)
            if [ -x "$SCRIPT_DIR/mihomo-rollback" ]; then
                "$SCRIPT_DIR/mihomo-rollback"
            else
                echo -e "${RED}❌ mihomo-rollback 脚本未找到${NC}"
            fi
            ;;
        10)
            ${EDITOR:-vi} "$CONFIG_DIR/config.yaml"
            echo -e "${GREEN}配置文件已保存${NC}"
            echo -e "${YELLOW}💡 运行 '8) 校验配置' 确认无误后，'4) 重启服务' 生效${NC}"
            ;;
        11)
            if [ -x "$SCRIPT_DIR/mihomo-logs" ]; then
                "$SCRIPT_DIR/mihomo-logs"
            else
                journalctl -u mihomo -u mihomo-tun --no-pager -n 50
            fi
            ;;
        12)
            if [ -x "$SCRIPT_DIR/mihomo-update" ]; then
                "$SCRIPT_DIR/mihomo-update"
            else
                echo -e "${RED}❌ mihomo-update 脚本未找到${NC}"
            fi
            ;;
        13)
            SETUP="$SCRIPT_DIR/../setup-service.sh"
            if [ -f "$SETUP" ]; then
                echo -e "${WHITE}选择模式:${NC}"
                echo "  1) 普通模式 (HTTP/SOCKS5)"
                echo "  2) TUN 模式 (透明代理)"
                read -p "请选择 [1/2]: " mode
                case $mode in
                    2) bash "$SETUP" tun ;;
                    *) bash "$SETUP" ;;
                esac
            else
                echo -e "${RED}❌ setup-service.sh 未找到${NC}"
            fi
            ;;
        14)
            if [ -x "$SCRIPT_DIR/test-all-proxy" ]; then
                "$SCRIPT_DIR/test-all-proxy"
            else
                echo -e "${RED}❌ test-all-proxy 脚本未找到${NC}"
            fi
            ;;
        15)
            if [ -x "$SCRIPT_DIR/mihomo-uninstall" ]; then
                "$SCRIPT_DIR/mihomo-uninstall"
            else
                echo -e "${RED}❌ mihomo-uninstall 脚本未找到${NC}"
            fi
            ;;
        0|q|Q)
            echo -e "${GREEN}👋 再见${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}无效选择，请输入 0-15${NC}"
            ;;
    esac

    echo ""
    read -p "按 Enter 返回菜单..." _
done
