#!/bin/bash
# mihomo-logs - 查看 mihomo 日志

LINES="${1:-50}"

if systemctl is-active --quiet mihomo.service 2>/dev/null; then
    journalctl -u mihomo.service -n "$LINES" --no-pager
    echo ""
    echo "💡 实时日志: journalctl -u mihomo.service -f"
elif [ -f "$HOME/.cache/mihomo/mihomo.log" ]; then
    tail -n "$LINES" "$HOME/.cache/mihomo/mihomo.log"
    echo ""
    echo "💡 实时日志: tail -f ~/.cache/mihomo/mihomo.log"
else
    echo "⚠️  未找到 mihomo 日志"
    echo "   systemd: journalctl -u mihomo.service"
    echo "   文件: ~/.cache/mihomo/mihomo.log"
fi
