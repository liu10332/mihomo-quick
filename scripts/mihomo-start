#!/bin/bash
# mihomo-start - 启动 mihomo 并配置环境

CONFIG_DIR="$HOME/.config/mihomo"
CACHE_DIR="$HOME/.cache/mihomo"
LOG_FILE="$CACHE_DIR/mihomo.log"
PID_FILE="$CACHE_DIR/mihomo.pid"

mkdir -p "$CACHE_DIR"

# 检查是否已运行
if [ -f "$PID_FILE" ]; then
    PID=$(cat "$PID_FILE")
    if kill -0 "$PID" 2>/dev/null; then
        echo "⚠️  Mihomo 已在运行 (PID: $PID)"
        echo "   停止: mihomo-stop | 重启: proxy-restart"
        exit 0
    else
        rm -f "$PID_FILE"
    fi
fi

# 检查配置文件
if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
    echo "❌ 配置文件不存在: $CONFIG_DIR/config.yaml"
    echo "   请先创建配置或运行 install.sh"
    exit 1
fi

echo "🚀 启动 Mihomo..."
echo "   配置: $CONFIG_DIR/config.yaml"
echo "   日志: $LOG_FILE"
echo "   端口: 7890 (HTTP) / 7891 (SOCKS5)"
echo "   面板: http://127.0.0.1:9090/ui"

# 启动
nohup ~/.local/bin/mihomo-core -d "$CONFIG_DIR" > "$LOG_FILE" 2>&1 &
MIHOMO_PID=$!
echo $MIHOMO_PID > "$PID_FILE"

sleep 2

if kill -0 $MIHOMO_PID 2>/dev/null; then
    echo "✅ Mihomo 启动成功 (PID: $MIHOMO_PID)"
    echo ""
    echo "📋 代理: http://127.0.0.1:7890 | socks5://127.0.0.1:7891"
    echo "💡 停止: mihomo-stop | 日志: mihomo-logs"
else
    echo "❌ 启动失败，查看日志: tail -f $LOG_FILE"
    rm -f "$PID_FILE"
    exit 1
fi
