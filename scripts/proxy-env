#!/bin/bash
# proxy-env - 代理环境变量管理（on/off/status/test）

PROXY_HOST="127.0.0.1"
PROXY_PORT="${HTTP_PROXY_PORT:-7890}"
SOCKS_PORT="${SOCKS_PROXY_PORT:-7891}"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

NO_PROXY_LIST="
*.anthropic.com
*.bigmodel.cn
*.dataeyes.ai
*.openai.com
*.openrouter.ai
*.volcengine.com
*.volces.com
*.xiaomimimo.com
*.163.com
*.alibaba.com
*.alipay.com
*.aliyun.com
*.baidu.com
*.bilibili.com
*.jd.com
*.mi.com
*.qq.com
*.sina.com.cn
*.sohu.com
*.taobao.com
*.tencent.com
*.tmall.com
*.weixin.qq.com
*.xiaomi.com
localhost
127.0.0.1
::1
10.*
172.16.*
172.17.*
172.18.*
172.19.*
172.20.*
172.21.*
172.22.*
172.23.*
172.24.*
172.25.*
172.26.*
172.27.*
172.28.*
172.29.*
172.30.*
172.31.*
192.168.*
"

case "${1:-}" in
    on|start)
        export http_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
        export https_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
        export HTTP_PROXY="http://${PROXY_HOST}:${PROXY_PORT}"
        export HTTPS_PROXY="http://${PROXY_HOST}:${PROXY_PORT}"
        export ALL_PROXY="socks5://${PROXY_HOST}:${SOCKS_PORT}"
        export all_proxy="socks5://${PROXY_HOST}:${SOCKS_PORT}"
        export no_proxy="$(echo ${NO_PROXY_LIST} | grep -v '^#' | grep -v '^$' | tr '\n' ',' | tr -s ',' | sed 's/^,//' | sed 's/,$//')"
        export NO_PROXY="${no_proxy}"
        echo -e "${GREEN}✅ 代理已启用${NC}"
        echo "   HTTP: http://${PROXY_HOST}:${PROXY_PORT}"
        echo "   SOCKS: socks5://${PROXY_HOST}:${SOCKS_PORT}"
        ;;
    off|stop)
        unset http_proxy https_proxy HTTP_PROXY HTTPS_PROXY ALL_PROXY all_proxy no_proxy NO_PROXY
        echo -e "${GREEN}✅ 代理已禁用${NC}"
        ;;
    status)
        echo -e "${BLUE}📊 代理状态:${NC}"
        echo "   http_proxy=${http_proxy:-未设置}"
        echo "   https_proxy=${https_proxy:-未设置}"
        echo "   ALL_PROXY=${ALL_PROXY:-未设置}"
        if pgrep -x "mihomo" > /dev/null 2>&1; then
            echo -e "   mihomo: ${GREEN}运行中${NC}"
        else
            echo -e "   mihomo: ${RED}未运行${NC}"
        fi
        ;;
    test)
        echo -e "${BLUE}🧪 测试代理...${NC}"
        echo -n "  大模型API直连 (volces.com): "
        curl -s -I --connect-timeout 5 https://ark.cn-beijing.volces.com 2>&1 | grep -q "HTTP/" && echo -e "${GREEN}✅${NC}" || echo -e "${RED}❌${NC}"
        echo -n "  代理连接: "
        if [ -n "$http_proxy" ]; then
            timeout 5 curl -s --proxy "$http_proxy" http://httpbin.org/ip > /dev/null 2>&1 && echo -e "${GREEN}✅${NC}" || echo -e "${RED}❌${NC}"
        else
            echo -e "${YELLOW}⚠️ 代理未设置${NC}"
        fi
        ;;
    config)
        read -p "代理主机 [${PROXY_HOST}]: " h; PROXY_HOST=${h:-$PROXY_HOST}
        read -p "HTTP端口 [${PROXY_PORT}]: " p; PROXY_PORT=${p:-$PROXY_PORT}
        read -p "SOCKS端口 [${SOCKS_PORT}]: " s; SOCKS_PORT=${s:-$SOCKS_PORT}
        echo "✅ 配置已更新: ${PROXY_HOST}:${PROXY_PORT}"
        ;;
    npm-on)
        command -v npm &>/dev/null && npm config set proxy "http://${PROXY_HOST}:${PROXY_PORT}" && npm config set https-proxy "http://${PROXY_HOST}:${PROXY_PORT}" && echo "✅ npm 代理已启用" || echo "❌ npm 未安装"
        ;;
    npm-off)
        command -v npm &>/dev/null && npm config delete proxy && npm config delete https-proxy && echo "✅ npm 代理已禁用" || echo "❌ npm 未安装"
        ;;
    *)
        echo "用法: proxy-env [on|off|status|test|config|npm-on|npm-off]"
        echo ""
        echo "  on/start     启用代理"
        echo "  off/stop     禁用代理"
        echo "  status       查看状态"
        echo "  test         测试连接"
        echo "  config       配置参数"
        echo "  npm-on       启用 npm 代理"
        echo "  npm-off      禁用 npm 代理"
        ;;
esac
