#!/bin/bash
# test-all-proxy - 综合代理测试

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

HTTP_PORT="${HTTP_PROXY_PORT:-7890}"
SOCKS_PORT="${SOCKS_PROXY_PORT:-7891}"
HTTP_PROXY="http://127.0.0.1:${HTTP_PORT}"

TOTAL=0; PASSED=0; FAILED=0

test_direct() {
    local name=$1 url=$2
    ((TOTAL++))
    echo -n "  $name (直连): "
    timeout 10 curl -s -I "$url" 2>&1 | grep -q "HTTP/" && { echo -e "${GREEN}✅${NC}"; ((PASSED++)); } || { echo -e "${RED}❌${NC}"; ((FAILED++)); }
}

test_proxy() {
    local name=$1 url=$2
    ((TOTAL++))
    echo -n "  $name (代理): "
    timeout 10 curl -s --proxy "$HTTP_PROXY" "$url" > /dev/null 2>&1 && { echo -e "${GREEN}✅${NC}"; ((PASSED++)); } || { echo -e "${RED}❌${NC}"; ((FAILED++)); }
}

echo -e "${CYAN}══════════════════════════════════════════════════════${NC}"
echo -e "${WHITE} mihomo-quick 综合代理测试${NC}"
echo -e "${CYAN}══════════════════════════════════════════════════════${NC}"
echo ""

# 环境检查
echo -e "${BLUE}1. 环境检查${NC}"
echo -n "  mihomo 进程: "
pgrep -x "mihomo" > /dev/null 2>&1 && echo -e "${GREEN}✅ 运行中${NC}" || { echo -e "${RED}❌ 未运行${NC}"; exit 1; }
echo -n "  HTTP端口 (${HTTP_PORT}): "
netstat -tuln 2>/dev/null | grep -q ":${HTTP_PORT} " && echo -e "${GREEN}✅ 监听${NC}" || echo -e "${RED}❌ 未监听${NC}"
echo -n "  环境变量: "
[ -n "$http_proxy" ] && echo -e "${GREEN}✅ $http_proxy${NC}" || echo -e "${YELLOW}⚠️ 未设置${NC}"
echo ""

# 大模型API直连
echo -e "${BLUE}2. 大模型API直连${NC}"
test_direct "Anthropic" "https://api.anthropic.com"
test_direct "火山引擎" "https://ark.cn-beijing.volces.com"
test_direct "智谱AI" "https://open.bigmodel.cn"
echo ""

# 代理连接
echo -e "${BLUE}3. 代理连接${NC}"
test_proxy "httpbin.org" "http://httpbin.org/ip"
test_proxy "Cloudflare" "https://cloudflare.com"
echo ""

# 外网访问
echo -e "${BLUE}4. 外网访问${NC}"
test_proxy "Google" "https://www.google.com"
test_proxy "GitHub" "https://github.com"
echo ""

# 国内直连
echo -e "${BLUE}5. 国内直连${NC}"
test_direct "百度" "https://www.baidu.com"
test_direct "腾讯" "https://www.qq.com"
echo ""

# 结果
echo -e "${CYAN}══════════════════════════════════════════════════════${NC}"
echo "  总计: $TOTAL  成功: ${GREEN}$PASSED${NC}  失败: ${RED}$FAILED${NC}"
[ $FAILED -eq 0 ] && echo -e "${GREEN}  🎉 全部通过！${NC}" || echo -e "${YELLOW}  ⚠️ 部分失败${NC}"
echo ""

# 代理IP
echo -e "${BLUE}6. 代理IP${NC}"
IP=$(timeout 10 curl -s --proxy "$HTTP_PROXY" "https://api.ipify.org?format=json" 2>/dev/null)
[ -n "$IP" ] && echo "  $IP" || echo "  无法获取"
echo ""
