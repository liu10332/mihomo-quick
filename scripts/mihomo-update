#!/bin/bash
# mihomo-update - 检查并更新 mihomo 内核、面板、GeoIP 数据库
set -e

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

CONFIG_DIR="$HOME/.config/mihomo"
MIHOMO_BIN="$HOME/.local/bin/mihomo-core"
MIRRORS=("https://ghfast.top" "https://gh-proxy.com" "")

# ===== 工具函数 =====

get_current_version() {
    if [ -x "$MIHOMO_BIN" ]; then
        "$MIHOMO_BIN" -v 2>/dev/null | grep -oP 'v[\d.]+' | head -1 || echo "unknown"
    else
        echo "未安装"
    fi
}

get_latest_release() {
    local repo="$1"
    curl -s --connect-timeout 5 "https://api.github.com/repos/$repo/releases/latest" 2>/dev/null \
        | grep '"tag_name"' | sed -E 's/.*"([^"]+)".*/\1/'
}

download_with_mirrors() {
    local url="$1"
    local output="$2"
    local desc="$3"

    for mirror in "${MIRRORS[@]}"; do
        local full="${mirror:+$mirror/}$url"
        echo "   尝试: ${full:0:70}..."
        if curl -sL --connect-timeout 10 --max-time 120 -o "$output" "$full" && [ -s "$output" ]; then
            return 0
        fi
    done
    echo -e "${RED}   ❌ $desc 下载失败${NC}"
    return 1
}

detect_arch() {
    local arch=$(uname -m)
    case $arch in
        x86_64)  echo "amd64" ;;
        aarch64) echo "arm64" ;;
        armv7l)  echo "armv7" ;;
        *)       echo "$arch" ;;
    esac
}

# ===== 更新 mihomo 内核 =====

update_core() {
    echo -e "${CYAN}━━━ 📦 mihomo 内核 ━━━${NC}"

    local current=$(get_current_version)
    echo "   当前版本: $current"

    local latest=$(get_latest_release "MetaCubeX/mihomo")
    if [ -z "$latest" ]; then
        echo -e "${RED}   ❌ 获取最新版本失败（网络问题）${NC}"
        return 1
    fi

    echo "   最新版本: $latest"

    if [ "$current" = "$latest" ]; then
        echo -e "${GREEN}   ✅ 已是最新版本${NC}"
        return 0
    fi

    local arch=$(detect_arch)
    echo -e "   架构: $arch"
    echo ""

    read -p "   是否更新？ [Y/n]: " yn || true
    [[ "$yn" =~ ^[Nn]$ ]] && return 0

    local url="https://github.com/MetaCubeX/mihomo/releases/download/$latest/mihomo-linux-${arch}-${latest}.gz"
    local temp="/tmp/mihomo-update.gz"

    echo "   📥 下载中..."
    if ! download_with_mirrors "$url" "$temp" "mihomo"; then
        return 1
    fi

    # 备份旧版本
    if [ -f "$MIHOMO_BIN" ]; then
        cp "$MIHOMO_BIN" "${MIHOMO_BIN}.bak"
        echo -e "   📋 已备份旧版本到 ${MIHOMO_BIN}.bak"
    fi

    gunzip -c "$temp" > "$MIHOMO_BIN"
    chmod +x "$MIHOMO_BIN"
    rm -f "$temp"

    local new_ver=$("$MIHOMO_BIN" -v 2>/dev/null | grep -oP 'v[\d.]+' | head -1)
    echo -e "${GREEN}   ✅ 更新完成: $current → $new_ver${NC}"

    # 如果 systemd 服务在运行，提示重启
    if systemctl is-active --quiet mihomo 2>/dev/null || systemctl is-active --quiet mihomo-tun 2>/dev/null; then
        echo ""
        echo -e "${YELLOW}   ⚠️ 检测到 mihomo 服务正在运行${NC}"
        read -p "   是否重启服务以使用新版本？ [Y/n]: " yn2 || true
        if [[ ! "$yn2" =~ ^[Nn]$ ]]; then
            if systemctl is-active --quiet mihomo-tun 2>/dev/null; then
                sudo systemctl restart mihomo-tun
                echo -e "${GREEN}   ✅ mihomo-tun 服务已重启${NC}"
            else
                sudo systemctl restart mihomo
                echo -e "${GREEN}   ✅ mihomo 服务已重启${NC}"
            fi
        fi
    fi
}

# ===== 更新 Dashboard 面板 =====

update_dashboard() {
    echo ""
    echo -e "${CYAN}━━━ 🖥️  Dashboard 面板 ━━━${NC}"

    local dash_dir="$CONFIG_DIR/dashboard"
    mkdir -p "$dash_dir"

    if [ -f "$dash_dir/index.html" ]; then
        echo -e "   当前状态: ${GREEN}已安装${NC}"
    else
        echo -e "   当前状态: ${YELLOW}未安装${NC}"
    fi

    local latest=$(get_latest_release "MetaCubeX/metacubexd")
    if [ -z "$latest" ]; then
        echo -e "${RED}   ❌ 获取最新版本失败${NC}"
        return 1
    fi

    echo "   最新版本: $latest"

    read -p "   是否更新/安装面板？ [Y/n]: " yn || true
    [[ "$yn" =~ ^[Nn]$ ]] && return 0

    local url="https://github.com/MetaCubeX/metacubexd/releases/download/$latest/compressed-dist.tgz"
    local temp="/tmp/metacubexd-update.tgz"

    echo "   📥 下载中..."
    if ! download_with_mirrors "$url" "$temp" "Dashboard"; then
        return 1
    fi

    # 备份旧面板
    if [ -f "$dash_dir/index.html" ]; then
        local backup="$CONFIG_DIR/dashboard.bak.$(date +%Y%m%d%H%M%S)"
        mv "$dash_dir" "$backup"
        mkdir -p "$dash_dir"
        echo -e "   📋 已备份旧面板到 $backup"
    fi

    if tar -xzf "$temp" -C "$dash_dir" 2>/dev/null; then
        rm -f "$temp"
        echo -e "${GREEN}   ✅ Dashboard 已更新到 $latest${NC}"
    else
        rm -f "$temp"
        echo -e "${RED}   ❌ 解压失败${NC}"
        return 1
    fi
}

# ===== 更新 GeoIP 数据库 =====

update_geoip() {
    echo ""
    echo -e "${CYAN}━━━ 🌍 GeoIP 数据库 ━━━${NC}"

    local geoip_file="$CONFIG_DIR/geoip.metadb"

    if [ -f "$geoip_file" ]; then
        local size=$(du -h "$geoip_file" | cut -f1)
        local mod=$(date -r "$geoip_file" '+%Y-%m-%d %H:%M')
        echo "   当前文件: $size (更新于 $mod)"
    else
        echo -e "   当前状态: ${YELLOW}未安装${NC}"
    fi

    read -p "   是否更新 GeoIP？ [Y/n]: " yn || true
    [[ "$yn" =~ ^[Nn]$ ]] && return 0

    local url="https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/country-lite.metadb"
    local temp="/tmp/geoip-update.metadb"

    echo "   📥 下载中..."
    if ! download_with_mirrors "$url" "$temp" "GeoIP"; then
        # 尝试完整版
        echo "   尝试完整版..."
        url="https://github.com/MetaCubeX/meta-rules-dat/releases/download/latest/country.metadb"
        if ! download_with_mirrors "$url" "$temp" "GeoIP (full)"; then
            return 1
        fi
    fi

    if [ -f "$geoip_file" ]; then
        cp "$geoip_file" "${geoip_file}.bak"
    fi

    mv "$temp" "$geoip_file"
    local new_size=$(du -h "$geoip_file" | cut -f1)
    echo -e "${GREEN}   ✅ GeoIP 已更新 ($new_size)${NC}"
}

# ===== 主流程 =====

echo -e "${WHITE}"
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                  mihomo-update 更新工具                     ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo -e "${NC}"

# 支持单独更新: mihomo-update core / dashboard / geoip
case "${1:-all}" in
    core)      update_core ;;
    dashboard) update_dashboard ;;
    geoip)     update_geoip ;;
    all)
        update_core
        update_dashboard
        update_geoip
        ;;
    *)
        echo "用法: $0 [core|dashboard|geoip|all]"
        echo ""
        echo "  core       仅更新 mihomo 内核"
        echo "  dashboard  仅更新 Dashboard 面板"
        echo "  geoip      仅更新 GeoIP 数据库"
        echo "  all        全部检查更新 (默认)"
        exit 1
        ;;
esac

echo ""
echo -e "${GREEN}━━━ 操作完成 ━━━${NC}"
