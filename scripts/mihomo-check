#!/bin/bash
# mihomo-check - 校验 mihomo 配置文件

CONFIG_DIR="${HOME}/.config/mihomo"
MIHOMO_BIN="$HOME/.local/bin/mihomo-core"

echo "🔍 校验 mihomo 配置..."
echo "   配置目录: $CONFIG_DIR"
echo ""

# 检查配置文件是否存在
if [ ! -f "$CONFIG_DIR/config.yaml" ]; then
    echo "❌ 配置文件不存在: $CONFIG_DIR/config.yaml"
    exit 1
fi

# 检查 mihomo 是否安装
if [ ! -f "$MIHOMO_BIN" ]; then
    echo "❌ mihomo 未安装: $MIHOMO_BIN"
    exit 1
fi

# YAML 语法检查（基础）
if command -v python3 &>/dev/null; then
    if python3 -c "import yaml; yaml.safe_load(open('$CONFIG_DIR/config.yaml'))" 2>/dev/null; then
        echo "  ✅ YAML 语法正确"
    else
        echo "  ❌ YAML 语法错误"
        python3 -c "import yaml; yaml.safe_load(open('$CONFIG_DIR/config.yaml'))" 2>&1
        exit 1
    fi
fi

# mihomo 内核校验
echo "  运行 mihomo -t 校验..."
OUTPUT=$("$MIHOMO_BIN" -d "$CONFIG_DIR" -t 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -eq 0 ]; then
    echo "  ✅ mihomo 配置校验通过"
    echo ""
    echo "✅ 配置正常，可以安全启动/重启"
else
    echo "  ❌ mihomo 配置校验失败:"
    echo ""
    echo "$OUTPUT"
    echo ""
    echo "💡 请检查配置文件: $CONFIG_DIR/config.yaml"
    exit 1
fi
