#!/bin/bash
# mihomo-add-sub - 交互式添加订阅并配置优先级

CONFIG_DIR="${HOME}/.config/mihomo"
CONFIG_FILE="$CONFIG_DIR/config.yaml"
MIHOMO_BIN=$(command -v mihomo-core 2>/dev/null || echo "$HOME/.local/bin/mihomo-core")

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m'

# 备份配置
backup_before_edit() {
    if [ -f "$CONFIG_FILE" ]; then
        local backup_dir="$CONFIG_DIR/backups"
        mkdir -p "$backup_dir"
        cp "$CONFIG_FILE" "$backup_dir/config.yaml.$(date +%Y%m%d_%H%M%S).bak"
    fi
}

# 获取已有订阅列表
get_providers() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "
import yaml, sys
with open('$CONFIG_FILE') as f:
    cfg = yaml.safe_load(f) or {}
providers = cfg.get('proxy-providers', {}) or {}
for name in providers:
    print(name)
" 2>/dev/null
    fi
}

# 获取已有代理组列表
get_groups() {
    if [ -f "$CONFIG_FILE" ]; then
        python3 -c "
import yaml, sys
with open('$CONFIG_FILE') as f:
    cfg = yaml.safe_load(f) or {}
groups = cfg.get('proxy-groups', []) or []
for g in groups:
    print(g.get('name', ''))
" 2>/dev/null
    fi
}

# 添加订阅到 config.yaml
add_provider() {
    local name=$1
    local url=$2
    local interval=$3
    local role=$4
    local proxy_chain=$5

    backup_before_edit

    python3 << PYEOF
import yaml, sys, copy

config_file = "$CONFIG_FILE"
name = "$name"
url = "$url"
interval = int("$interval")
role = "$role"
proxy_chain = "$proxy_chain" or None

with open(config_file) as f:
    cfg = yaml.safe_load(f) or {}

# 确保必要字段存在
if 'proxy-providers' not in cfg or cfg['proxy-providers'] is None:
    cfg['proxy-providers'] = {}
if 'proxy-groups' not in cfg or cfg['proxy-groups'] is None:
    cfg['proxy-groups'] = []

# 添加 provider
provider = {
    'type': 'http',
    'url': url,
    'interval': interval,
    'path': f'./providers/{name}.yaml',
    'health-check': {
        'enable': True,
        'interval': 600,
        'url': 'http://cp.cloudflare.com/generate_204'
    },
    'override': {
        'skip-cert-verify': True
    }
}
if proxy_chain:
    provider['proxy'] = proxy_chain

cfg['proxy-providers'][name] = provider

# 获取现有的代理组名称
existing_groups = [g['name'] for g in cfg['proxy-groups']]

# 根据角色设置代理组
if role == 'primary':
    # 主订阅：创建 url-test 组（如果不存在）
    primary_name = '⭐ 主订阅'
    fallback_name = '🔄 故障转移'
    select_name = '📱 手动选择'

    # 创建或更新主订阅 url-test 组
    primary_found = False
    for g in cfg['proxy-groups']:
        if g['name'] == primary_name:
            if 'use' not in g:
                g['use'] = []
            if name not in g['use']:
                g['use'].append(name)
            primary_found = True
            break
    if not primary_found:
        cfg['proxy-groups'].insert(0, {
            'name': primary_name,
            'type': 'url-test',
            'use': [name],
            'url': 'http://cp.cloudflare.com/generate_204',
            'interval': 300,
            'tolerance': 200,
            'lazy': True
        })

    # 确保故障转移组存在
    fallback_found = False
    for g in cfg['proxy-groups']:
        if g['name'] == fallback_name:
            fallback_found = True
            break
    if not fallback_found:
        # 插入到主订阅之后
        idx = next((i for i, g in enumerate(cfg['proxy-groups']) if g['name'] == primary_name), 0) + 1
        cfg['proxy-groups'].insert(idx, {
            'name': fallback_name,
            'type': 'fallback',
            'proxies': [primary_name],
            'url': 'http://cp.cloudflare.com/generate_204',
            'interval': 300,
            'lazy': True
        })

    # 确保手动选择组存在
    select_found = False
    for g in cfg['proxy-groups']:
        if g['name'] == select_name:
            if 'use' not in g:
                g['use'] = []
            if name not in g['use']:
                g['use'].append(name)
            select_found = True
            break
    if not select_found:
        cfg['proxy-groups'].append({
            'name': select_name,
            'type': 'select',
            'use': [name],
            'proxies': [fallback_name, primary_name, 'DIRECT']
        })

elif role == 'backup':
    # 备用订阅：添加到故障转移组
    fallback_name = '🔄 故障转移'
    primary_name = '⭐ 主订阅'
    select_name = '📱 手动选择'

    # 添加到故障转移组的 proxies
    for g in cfg['proxy-groups']:
        if g['name'] == fallback_name:
            if 'proxies' not in g:
                g['proxies'] = [primary_name]
            if name not in g['proxies']:
                g['proxies'].append(name)
            break
    else:
        # 故障转移组不存在，创建它
        cfg['proxy-groups'].append({
            'name': fallback_name,
            'type': 'fallback',
            'proxies': [primary_name, name],
            'url': 'http://cp.cloudflare.com/generate_204',
            'interval': 300,
            'lazy': True
        })

    # 添加到手动选择组
    for g in cfg['proxy-groups']:
        if g['name'] == select_name:
            if 'use' not in g:
                g['use'] = []
            if name not in g['use']:
                g['use'].append(name)
            break

elif role == 'manual':
    # 仅手动选择
    select_name = '📱 手动选择'

    for g in cfg['proxy-groups']:
        if g['name'] == select_name:
            if 'use' not in g:
                g['use'] = []
            if name not in g['use']:
                g['use'].append(name)
            break
    else:
        cfg['proxy-groups'].append({
            'name': select_name,
            'type': 'select',
            'use': [name],
            'proxies': ['DIRECT']
        })

# 写入配置
with open(config_file, 'w') as f:
    yaml.dump(cfg, f, default_flow_style=False, allow_unicode=True, sort_keys=False)

print(f"✅ 订阅 [{name}] 已添加为{{'primary': '主订阅', 'backup': '备用订阅', 'manual': '手动选择'}}[role]")
PYEOF
}

# 主流程
echo -e "${CYAN}"
echo "╔══════════════════════════════════════════════════════════════╗"
echo "║                     添加订阅                                ║"
echo "╚══════════════════════════════════════════════════════════════╝"
echo -e "${NC}"

# 检查配置文件
if [ ! -f "$CONFIG_FILE" ]; then
    echo -e "${RED}❌ 配置文件不存在: $CONFIG_FILE${NC}"
    echo "   请先运行 install.sh"
    exit 1
fi

# 显示已有订阅
EXISTING=$(get_providers)
if [ -n "$EXISTING" ]; then
    echo -e "${WHITE}当前订阅:${NC}"
    echo "$EXISTING" | while read p; do echo "  - $p"; done
    echo ""
fi

# 获取订阅名称
read -p "订阅名称: " sub_name
if [ -z "$sub_name" ]; then
    echo -e "${RED}❌ 名称不能为空${NC}"
    exit 1
fi

# 获取订阅URL
read -p "订阅URL: " sub_url
if [ -z "$sub_url" ]; then
    echo -e "${RED}❌ URL 不能为空${NC}"
    exit 1
fi

# 更新间隔
read -p "更新间隔(秒) [3600]: " sub_interval
sub_interval=${sub_interval:-3600}

# 订阅角色
echo ""
echo -e "${WHITE}订阅角色:${NC}"
echo "  1. ⭐ 主订阅（优先使用，自动选最快节点）"
echo "  2. 🔄 备用订阅（主挂了自动切换）"
echo "  3. 📱 仅手动选择（不参与自动切换）"
read -p "请选择 [1-3]: " role_choice
case $role_choice in
    1) role="primary" ;;
    2) role="backup" ;;
    3) role="manual" ;;
    *) echo -e "${YELLOW}默认选择: 主订阅${NC}"; role="primary" ;;
esac

# 代理链
echo ""
echo -e "${WHITE}此订阅是否需要通过代理下载？（订阅站被墙时需要）${NC}"
echo "  1. 直接下载（默认）"
echo "  2. 通过已有代理组下载"
read -p "请选择 [1]: " proxy_choice
proxy_chain=""
if [ "$proxy_choice" = "2" ]; then
    echo ""
    echo "已有代理组:"
    get_groups | while read g; do [ -n "$g" ] && echo "  - $g"; done
    echo ""
    read -p "代理组名称: " proxy_chain
fi

# 执行添加
echo ""
add_provider "$sub_name" "$sub_url" "$sub_interval" "$role" "$proxy_chain"

# 创建 providers 缓存目录
mkdir -p "$CONFIG_DIR/providers"

# 询问是否重启
echo ""
read -p "是否重启 mihomo 生效？ [Y/n]: " yn
case ${yn:-y} in
    [Yy]*)
        if command -v mihomo-stop &>/dev/null; then
            mihomo-stop 2>/dev/null
            sleep 1
            mihomo-start
        elif systemctl is-active --quiet mihomo.service 2>/dev/null; then
            sudo systemctl restart mihomo.service
            echo "✅ mihomo 已重启"
        else
            echo "💡 请手动启动: proxy-start"
        fi
        ;;
    *)
        echo "💡 稍后重启: proxy-restart"
        ;;
esac
