# 系统代理配置模板
# 继承自base.yaml.template

# 系统代理配置
mixed-port: {{HTTP_PORT}}
socks-port: {{SOCKS_PORT}}
allow-lan: {{ALLOW_LAN}}
bind-address: '{{BIND_ADDRESS}}'
mode: {{MODE}}

# 系统代理模式下的额外配置
# 注意：系统代理模式下，TUN配置应该禁用
tun:
  enable: false

# 系统代理模式下的DNS配置
dns:
  enable: {{DNS_ENABLED}}
  enhanced-mode: {{DNS_MODE}}
  fake-ip-range: {{FAKE_IP_RANGE}}
  fake-ip-filter:
  {{FAKE_IP_FILTER}}
  nameserver:
  {{NAMESERVER}}
  fallback:
  {{FALLBACK_DNS}}
